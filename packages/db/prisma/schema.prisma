// Rovrum content model — the source-agnostic heart of the pipeline.
// See docs/ARCHITECTURE.md §5 for the design rationale.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Runtime / build-time queries use the pooled connection (ideal for the
  // short-lived Vercel build and any serverless-ish caller).
  url      = env("DATABASE_URL")
  // Prisma CLI (migrate / db push) needs a direct, unpooled connection. On
  // Neon this is the non `-pooler` host. Falls back to DATABASE_URL locally,
  // where a single plain Postgres serves both (see prisma.config.ts).
  directUrl = env("DIRECT_URL")
}

enum Vertical {
  NEWS
  SPORTS
  EVENTS
  JOBS
}

enum SourceType {
  RSS
  HTML
  API
  PLAYWRIGHT
}

enum SocialPostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
}

enum IngestRunStatus {
  RUNNING
  SUCCESS
  FAILED
}

/// A registered source (feed / API / page) we ingest from.
model Source {
  id            String     @id @default(cuid())
  name          String
  type          SourceType
  /// The vertical every item from this source is filed under.
  vertical      Vertical
  /// Unique so the seed can upsert on it and we never register a feed twice.
  url           String     @unique
  /// Per-source fetch/scrape config (selectors, auth hints, etc.).
  config        Json?
  /// How often to fetch, in minutes.
  fetchCadence  Int        @default(60)
  enabled       Boolean    @default(true)
  lastFetchedAt DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  contentItems ContentItem[]
  ingestRuns   IngestRun[]

  @@map("sources")
}

/// The normalized unit every source adapter produces. Aggregator model:
/// headline + excerpt + attribution + canonical link only — never full content.
model ContentItem {
  id       String @id @default(cuid())
  sourceId String
  source   Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  vertical     Vertical
  title        String
  excerpt      String
  canonicalUrl String
  imageUrl     String?
  author       String?
  publishedAt  DateTime?

  /// Stable hash of the item for dedup across runs/sources.
  contentHash String  @unique
  /// Rotherham-relevance geo/tags.
  location    String?

  /// Cross-publisher story cluster this item belongs to (null = unclustered
  /// singleton). Fuzzy title clustering groups near-duplicate stories from
  /// different outlets. See docs/plans/dedup-clustering.md.
  clusterId String?
  cluster   StoryCluster? @relation("StoryClusterMembers", fields: [clusterId], references: [id], onDelete: SetNull)
  /// Back-relation: the cluster (if any) this item is the canonical of.
  canonicalOf StoryCluster? @relation("StoryClusterCanonical")

  /// Original payload, so we never lose data the model doesn't yet capture.
  raw          Json
  /// Vertical-specific extensions (kept as jsonb for now).
  eventDetails Json?
  jobDetails   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  socialPosts SocialPost[]

  @@index([vertical])
  @@index([publishedAt])
  @@index([sourceId])
  @@index([clusterId])
  @@map("content_items")
}

/// A cross-publisher story cluster: near-duplicate items from different outlets
/// grouped so the feed shows one canonical item with "also reported by" members.
/// See docs/plans/dedup-clustering.md.
model StoryCluster {
  id String @id @default(cuid())

  /// The item shown as the face of the story. Optional + SetNull so deleting the
  /// canonical item never blocks deletion or drops the cluster — the worker
  /// re-elects a canonical from the remaining members.
  canonicalItemId String?      @unique
  canonicalItem   ContentItem? @relation("StoryClusterCanonical", fields: [canonicalItemId], references: [id], onDelete: SetNull)

  /// All items in the cluster (including the canonical). SetNull on the member
  /// side leaves an item as an unclustered singleton if the cluster is deleted.
  members ContentItem[] @relation("StoryClusterMembers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("story_clusters")
}

/// A generated social post: draft -> scheduled -> published, with per-platform
/// variants (text/image/video) held in `variants`.
model SocialPost {
  id            String       @id @default(cuid())
  contentItemId String?
  contentItem   ContentItem? @relation(fields: [contentItemId], references: [id], onDelete: SetNull)

  status       SocialPostStatus @default(DRAFT)
  /// Per-platform variants keyed by platform, e.g. { x: {...}, tiktok: { video } }.
  variants     Json
  scheduledFor DateTime?
  publishedAt  DateTime?
  error        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([scheduledFor])
  @@map("social_posts")
}

/// Observability for each ingestion run: what ran, what it found, what failed.
model IngestRun {
  id       String  @id @default(cuid())
  sourceId String?
  source   Source? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  status     IngestRunStatus @default(RUNNING)
  startedAt  DateTime        @default(now())
  finishedAt DateTime?
  itemsFound Int             @default(0)
  itemsNew   Int             @default(0)
  error      String?
  stats      Json?

  @@index([sourceId])
  @@index([startedAt])
  @@map("ingest_runs")
}
