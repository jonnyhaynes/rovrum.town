{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  // Turbo 2 runs tasks in Strict Environment Mode: task processes only see env
  // vars declared here. The DB connection vars must be listed or tasks that talk
  // to Postgres (workers integration tests, Prisma generate, SSG build) can't
  // read them — they'd fall back to a stale .env or fail outright in CI.
  "globalEnv": ["DATABASE_URL", "DIRECT_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types", "db:generate"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "db:generate": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
