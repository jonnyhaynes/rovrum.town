---
// Base HTML shell for the Rovrum web app. Brand palette + type from
// brand/BRAND.md, reusing the holding page's setup so the app is on-brand from
// day one. SEO tags (per-page OG, sitemap, canonical) land in the SEO ticket.
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <link rel="preconnect" href="https://fonts.bunny.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.bunny.net/css?family=bitter:600,700,700i|inter:400,600"
    />
  </head>
  <body>
    <slot />
    <style is:global>
      :root {
        --ink: #141518;
        --paper: #f7f5f2;
        --stone: #8a8578;
        --red: #b23a2e;
        --slate: #2a2c31;
        --line: #e2ddd4;

        --sans:
          "Inter", ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial,
          sans-serif;
        --serif: "Bitter", Georgia, "Times New Roman", serif;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html {
        -webkit-text-size-adjust: 100%;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background: var(--paper);
        color: var(--ink);
        font-family: var(--sans);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      a {
        color: inherit;
      }

      h1,
      h2,
      h3 {
        font-family: var(--serif);
        font-weight: 700;
      }
    </style>
  </body>
</html>
