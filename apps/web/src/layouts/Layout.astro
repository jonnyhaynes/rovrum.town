---
// Base HTML shell for the Rovrum web app — a broadsheet newspaper front page.
// Brand palette + type from brand/BRAND.md. The shared masthead, signup strip
// and footer wrap every page's <slot> content so every vertical inherits the
// newspaper shell. SEO tags (per-page OG, sitemap, canonical) land in the SEO
// ticket. See docs/plans/news-broadsheet-design.md.
import Masthead from "../components/Masthead.astro";
import SignupStrip from "../components/SignupStrip.astro";
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
  title: string;
  description?: string;
  /** Which masthead section is active (defaults to news). */
  section?: string;
}

const { title, description, section = "news" } = Astro.props;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <link rel="preconnect" href="https://fonts.bunny.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.bunny.net/css?family=bitter:600,700,700i|inter:400,600"
    />
  </head>
  <body>
    <div class="sheet">
      <Masthead active={section} />
      <main>
        <slot />
      </main>
      <SignupStrip />
      <SiteFooter />
    </div>

    <style is:global>
      :root {
        --ink: #141518;
        --paper: #f7f5f2;
        --stone: #8a8578;
        --red: #b23a2e;
        --slate: #2a2c31;
        --line: #e2ddd4;
        /* neutral biased warm toward the paper ground, not a pure grey */
        --line-strong: #cec7ba;

        --sans:
          "Inter", ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial,
          sans-serif;
        --serif: "Bitter", Georgia, "Times New Roman", serif;

        --gutter: clamp(1rem, 3.5vw, 2.75rem);
        --maxw: 74rem;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html {
        -webkit-text-size-adjust: 100%;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at 20% 10%, rgba(20, 21, 24, 0.015), transparent 60%), var(--paper);
        color: var(--ink);
        font-family: var(--sans);
        line-height: 1.55;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      .sheet {
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 0 var(--gutter) 4rem;
      }

      a {
        color: inherit;
      }
      a:focus-visible {
        outline: 2px solid var(--red);
        outline-offset: 3px;
      }

      h1,
      h2,
      h3 {
        font-family: var(--serif);
        font-weight: 700;
      }
    </style>
  </body>
</html>
