---
// Placeholder home of the News vertical (served at /news via `base`). The real
// feed — cards, attribution, pagination reading @rovrum/db — lands in the
// web-news-feed ticket. This exists so the scaffold builds and deploys green
// alongside the untouched holding page. See docs/plans/phase-2-web-mvp.md.
import Layout from "../layouts/Layout.astro";
---

<Layout title="News — Rovrum" description="Local news from across Rotherham, all in one place.">
  <main>
    <p class="eyebrow">Rovrum · News</p>
    <h1>Everything Rovrum, in one spot.</h1>
    <p>The Rotherham news feed is on its way.</p>
  </main>
  <style>
    main {
      max-width: 34rem;
      margin: 0 auto;
      padding: 4rem 1.25rem;
    }
    .eyebrow {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: var(--stone);
      margin: 0 0 0.5rem;
    }
    h1 {
      font-size: clamp(1.75rem, 5vw, 2.5rem);
      margin: 0 0 1rem;
    }
  </style>
</Layout>
