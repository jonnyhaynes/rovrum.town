---
// The News feed — a broadsheet front page under /news (/news, /news/2, …).
// SSG: getStaticPaths pulls every NEWS item and paginate() slices it. Page 1 is
// composed as a front page (lead + secondary stack + three-column run); pages 2+
// fall back to a clean column list. Every headline links OUT to its source
// (aggregator boundary). See docs/plans/news-broadsheet-design.md.
import type { GetStaticPaths, Page } from "astro";
import Layout from "../../layouts/Layout.astro";
import LeadStory from "../../components/LeadStory.astro";
import Brief from "../../components/Brief.astro";
import StoryCard from "../../components/StoryCard.astro";
import Pagination from "../../components/Pagination.astro";
import { getAllNews, NEWS_PER_PAGE, type NewsCardView } from "../../lib/news.js";

export const getStaticPaths = (async ({ paginate }) => {
  const items = await getAllNews();
  return paginate(items, { pageSize: NEWS_PER_PAGE });
}) satisfies GetStaticPaths;

interface Props {
  page: Page<NewsCardView>;
}

const { page } = Astro.props;
const isFront = page.currentPage === 1;

// Front-page split: 1 lead, up to 3 briefs, the rest into the column run.
const [lead, ...restFront] = page.data;
const briefs = restFront.slice(0, 3);
const run = restFront.slice(3);

const title = isFront ? "News — Rovrum" : `News — page ${page.currentPage} — Rovrum`;
---

<Layout
  title={title}
  description="Local news from across Rotherham, all in one place."
  section="news"
>
  {
    page.data.length === 0 ? (
      <p class="feed__empty">Nowt to show just yet — check back soon.</p>
    ) : isFront && lead ? (
      <>
        <div class="front">
          <div class="front__lead">
            <LeadStory item={lead} />
          </div>
          {briefs.length > 0 && (
            <aside class="front__aside">
              <p class="aside__label">Also this morning</p>
              {briefs.map((item) => (
                <Brief item={item} />
              ))}
            </aside>
          )}
        </div>

        {run.length > 0 && (
          <section>
            <div class="band">
              <h2>More from Rotherham</h2>
              <small>Updated hourly</small>
            </div>
            <div class="columns">
              {run.map((item) => (
                <StoryCard item={item} />
              ))}
            </div>
          </section>
        )}
      </>
    ) : (
      <section>
        <div class="band">
          <h2>News</h2>
          <small>
            Page {page.currentPage} of {page.lastPage}
          </small>
        </div>
        <div class="list">
          {page.data.map((item) => (
            <StoryCard item={item} />
          ))}
        </div>
      </section>
    )
  }

  <Pagination
    prevUrl={page.url.prev}
    nextUrl={page.url.next}
    current={page.currentPage}
    last={page.lastPage}
  />
</Layout>

<style>
  .feed__empty {
    color: var(--stone);
    padding: 3rem 0;
    font-size: 1.1rem;
  }

  /* ── Front page: lead + secondary stack ─────────────────── */
  .front {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    padding-top: 1.75rem;
  }
  @media (min-width: 52rem) {
    .front {
      grid-template-columns: 1.7fr 1fr;
      column-gap: 2.25rem;
    }
  }

  .front__aside {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 3px solid var(--ink);
  }
  @media (min-width: 52rem) {
    .front__aside {
      margin-top: 0;
      padding-top: 0;
      border-top: 0;
      border-left: 1px solid var(--line-strong);
      padding-left: 2.25rem;
    }
  }
  .aside__label {
    font-family: var(--serif);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--ink);
  }

  /* ── Section band ───────────────────────────────────────── */
  .band {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin: 3rem 0 0;
    padding-bottom: 0.6rem;
    border-bottom: 3px solid var(--ink);
  }
  .band h2 {
    font-family: var(--serif);
    font-weight: 700;
    font-size: 1.4rem;
    margin: 0;
  }
  .band small {
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--stone);
    margin-left: auto;
  }

  /* ── Three-column run (front page) ──────────────────────── */
  .columns {
    padding-top: 1.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 40rem) {
    .columns {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (min-width: 60rem) {
    .columns {
      grid-template-columns: 1fr 1fr 1fr;
      gap: 0;
    }
    /* vertical hairlines between columns */
    .columns > :global(.story) {
      padding: 0 1.75rem;
      border-left: 1px solid var(--line);
    }
    .columns > :global(.story:nth-child(3n + 1)) {
      padding-left: 0;
      border-left: 0;
    }
  }

  /* ── List (pages 2+) ────────────────────────────────────── */
  .list {
    padding-top: 1.5rem;
    display: grid;
    gap: 1.5rem;
  }
  .list > :global(.story) {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--line);
  }
</style>
