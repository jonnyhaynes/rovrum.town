---
// The News feed — a broadsheet front page under /news (/news, /news/2, …).
// SSG: getStaticPaths pulls every NEWS item and pages it by hand (paginate()
// can't give page 1 a different size). Page 1 is a composed front page — 1 lead
// + 3 briefs + a 3-story "More from Rotherham" run (7 items). Pages 2+ are a
// three-across grid of the remaining items. Every headline links OUT to its
// source (aggregator boundary). See docs/plans/news-broadsheet-design.md.
import type { GetStaticPaths } from "astro";
import Layout from "../../layouts/Layout.astro";
import LeadStory from "../../components/LeadStory.astro";
import Brief from "../../components/Brief.astro";
import StoryCard from "../../components/StoryCard.astro";
import Pagination from "../../components/Pagination.astro";
import {
  getAllNews,
  NEWS_PER_PAGE,
  FRONT_BRIEFS,
  FRONT_RUN,
  FRONT_TOTAL,
  type NewsCardView,
} from "../../lib/news.js";

export const getStaticPaths = (async () => {
  const items = await getAllNews();

  // Page 1 = first FRONT_TOTAL items; the rest paginate in grids of NEWS_PER_PAGE.
  const front = items.slice(0, FRONT_TOTAL);
  const rest = items.slice(FRONT_TOTAL);
  const restPages = Math.ceil(rest.length / NEWS_PER_PAGE);
  const lastPage = 1 + restPages;

  const path = (n: number) => (n === 1 ? undefined : String(n));

  const pages = [
    {
      params: { page: path(1) },
      props: { current: 1, lastPage, items: front },
    },
    ...Array.from({ length: restPages }, (_, i) => {
      const current = i + 2;
      return {
        params: { page: path(current) },
        props: {
          current,
          lastPage,
          items: rest.slice(i * NEWS_PER_PAGE, (i + 1) * NEWS_PER_PAGE),
        },
      };
    }),
  ];

  return pages;
}) satisfies GetStaticPaths;

interface Props {
  current: number;
  lastPage: number;
  items: NewsCardView[];
}

const { current, lastPage, items } = Astro.props;
const isFront = current === 1;

// Front-page split: 1 lead, 3 briefs, 3 in the run.
const [lead, ...restFront] = items;
const briefs = restFront.slice(0, FRONT_BRIEFS);
const run = restFront.slice(FRONT_BRIEFS, FRONT_BRIEFS + FRONT_RUN);

// Pager URLs (manual paging → build them ourselves).
const prevUrl = current === 1 ? undefined : current === 2 ? "/news" : `/news/${current - 1}`;
const nextUrl = current < lastPage ? `/news/${current + 1}` : undefined;

const title = isFront ? "News — Rovrum" : `News — page ${current} — Rovrum`;
---

<Layout
  title={title}
  description="Local news from across Rotherham, all in one place."
  section="news"
>
  {
    items.length === 0 ? (
      <p class="feed__empty">Nowt to show just yet — check back soon.</p>
    ) : isFront && lead ? (
      <>
        <div class="front">
          <div class="front__lead">
            <LeadStory item={lead} />
          </div>
          {briefs.length > 0 && (
            <aside class="front__aside">
              <p class="aside__label">Also this morning</p>
              {briefs.map((item) => (
                <Brief item={item} />
              ))}
            </aside>
          )}
        </div>

        {run.length > 0 && (
          <section>
            <div class="band">
              <h2>More from Rotherham</h2>
              <small>Updated hourly</small>
            </div>
            <div class="columns">
              {run.map((item) => (
                <StoryCard item={item} />
              ))}
            </div>
          </section>
        )}
      </>
    ) : (
      <section>
        <div class="band">
          <h2>News</h2>
          <small>
            Page {current} of {lastPage}
          </small>
        </div>
        <div class="columns">
          {items.map((item) => (
            <StoryCard item={item} />
          ))}
        </div>
      </section>
    )
  }

  <Pagination prevUrl={prevUrl} nextUrl={nextUrl} current={current} last={lastPage} />
</Layout>

<style>
  .feed__empty {
    color: var(--stone);
    padding: 3rem 0;
    font-size: 1.1rem;
  }

  /* ── Front page: lead + secondary stack ─────────────────── */
  .front {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    padding-top: 1.75rem;
  }
  @media (min-width: 52rem) {
    .front {
      grid-template-columns: 1.7fr 1fr;
      column-gap: 2.25rem;
    }
  }

  .front__aside {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 3px solid var(--ink);
  }
  @media (min-width: 52rem) {
    .front__aside {
      margin-top: 0;
      padding-top: 0;
      border-top: 0;
      border-left: 1px solid var(--line-strong);
      padding-left: 2.25rem;
    }
  }
  .aside__label {
    font-family: var(--serif);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--ink);
  }

  /* ── Section band ───────────────────────────────────────── */
  .band {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin: 3rem 0 0;
    padding-bottom: 0.6rem;
    border-bottom: 3px solid var(--ink);
  }
  .band h2 {
    font-family: var(--serif);
    font-weight: 700;
    font-size: 1.4rem;
    margin: 0;
  }
  .band small {
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--stone);
    margin-left: auto;
  }

  /* ── Three-column run (front page) ──────────────────────── */
  .columns {
    padding-top: 1.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 40rem) {
    .columns {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (min-width: 60rem) {
    .columns {
      grid-template-columns: 1fr 1fr 1fr;
      column-gap: 1.75rem;
      row-gap: 2.5rem;
    }
    /* vertical hairlines between columns */
    .columns > :global(.story:not(:nth-child(3n + 1))) {
      padding-left: 1.75rem;
      border-left: 1px solid var(--line);
    }
  }
</style>
