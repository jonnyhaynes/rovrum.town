---
// The News listing — paginated three-across grid under /news (/news, /news/2, …).
// Every headline links OUT to its source (aggregator boundary).
import type { GetStaticPaths } from "astro";
import Layout from "../../layouts/Layout.astro";
import StoryCard from "../../components/StoryCard.astro";
import Pagination from "../../components/Pagination.astro";
import { getAllNews, NEWS_PER_PAGE, type NewsCardView } from "../../lib/news.js";

export const getStaticPaths = (async () => {
  const items = await getAllNews();
  const totalPages = Math.ceil(items.length / NEWS_PER_PAGE);

  const path = (n: number) => (n === 1 ? undefined : String(n));

  return Array.from({ length: totalPages }, (_, i) => {
    const current = i + 1;
    return {
      params: { page: path(current) },
      props: {
        current,
        lastPage: totalPages,
        items: items.slice(i * NEWS_PER_PAGE, (i + 1) * NEWS_PER_PAGE),
      },
    };
  });
}) satisfies GetStaticPaths;

interface Props {
  current: number;
  lastPage: number;
  items: NewsCardView[];
}

const { current, lastPage, items } = Astro.props;

const prevUrl = current === 1 ? undefined : current === 2 ? "/news" : `/news/${current - 1}`;
const nextUrl = current < lastPage ? `/news/${current + 1}` : undefined;
const title = current === 1 ? "News — Rovrum" : `News — page ${current} — Rovrum`;
---

<Layout
  title={title}
  description="Local news from across Rotherham, all in one place."
  section="news"
>
  {
    items.length === 0 ? (
      <p class="feed__empty">Nowt to show just yet — check back soon.</p>
    ) : (
      <section>
        <div class="band">
          <h2>News</h2>
          <small>
            Page {current} of {lastPage}
          </small>
        </div>
        <div class="columns">
          {items.map((item) => (
            <StoryCard item={item} />
          ))}
        </div>
      </section>
    )
  }

  <Pagination prevUrl={prevUrl} nextUrl={nextUrl} current={current} last={lastPage} />
</Layout>

<style>
  .feed__empty {
    color: var(--stone);
    padding: 3rem 0;
    font-size: 1.1rem;
  }

  .band {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin: 3rem 0 0;
    padding-bottom: 0.6rem;
    border-bottom: 3px solid var(--ink);
  }
  .band h2 {
    font-family: var(--serif);
    font-weight: 700;
    font-size: 1.4rem;
    margin: 0;
  }
  .band small {
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--stone);
    margin-left: auto;
  }

  .columns {
    padding-top: 1.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 40rem) {
    .columns {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (min-width: 60rem) {
    .columns {
      grid-template-columns: 1fr 1fr 1fr;
      column-gap: 2.5rem;
      row-gap: 2.5rem;
    }
    .columns > :global(.story:not(:nth-child(3n + 1))) {
      position: relative;
    }
    .columns > :global(.story:not(:nth-child(3n + 1)))::before {
      content: "";
      position: absolute;
      left: -1.25rem;
      top: 0;
      bottom: 0;
      width: 1px;
      background: var(--line);
    }
  }
</style>
