---
// A single news item. Aggregator boundary (docs/plans/phase-2-web-mvp.md §5):
// the headline links OUT to the source's canonicalUrl — we never link to an
// on-site page, and never render full content. Just headline + excerpt +
// attribution + optional image.
import type { NewsCardView } from "../lib/news.js";
import { relativeTime } from "../lib/format.js";

interface Props {
  item: NewsCardView;
}

const { item } = Astro.props;
const when = item.publishedAt ? relativeTime(item.publishedAt) : null;
---

<article class="card">
  {
    item.imageUrl && (
      <a
        class="card__image-link"
        href={item.canonicalUrl}
        target="_blank"
        rel="noopener noreferrer"
        tabindex="-1"
        aria-hidden="true"
      >
        <img class="card__image" src={item.imageUrl} alt="" loading="lazy" />
      </a>
    )
  }
  <div class="card__body">
    <h2 class="card__title">
      <a href={item.canonicalUrl} target="_blank" rel="noopener noreferrer">
        {item.title}
      </a>
    </h2>
    <p class="card__excerpt">{item.excerpt}</p>
    <p class="card__meta">
      <span class="card__source">{item.sourceName}</span>
      {when && <span class="card__time"> · {when}</span>}
    </p>
  </div>
</article>

<style>
  .card {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--line);
  }

  @media (min-width: 34rem) {
    .card:has(.card__image-link) {
      grid-template-columns: 8rem 1fr;
      gap: 1.25rem;
      align-items: start;
    }
  }

  .card__image-link {
    display: block;
  }

  .card__image {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 6px;
    background: var(--line);
  }

  .card__title {
    font-family: var(--serif);
    font-size: 1.15rem;
    line-height: 1.3;
    margin: 0 0 0.4rem;
  }

  .card__title a {
    text-decoration: none;
  }

  .card__title a:hover {
    color: var(--red);
    text-decoration: underline;
  }

  .card__excerpt {
    margin: 0 0 0.5rem;
    color: var(--slate);
  }

  .card__meta {
    margin: 0;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--stone);
  }

  .card__source {
    font-weight: 600;
  }
</style>
