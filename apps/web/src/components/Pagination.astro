---
// Prev/next pager for the feed. URLs come from Astro's paginate() (page.url.prev
// / page.url.next), which are undefined at the ends — we omit the link there.
interface Props {
  prevUrl?: string | undefined;
  nextUrl?: string | undefined;
  current: number;
  last: number;
}

const { prevUrl, nextUrl, current, last } = Astro.props;
---

{
  last > 1 && (
    <nav class="pager" aria-label="Pagination">
      {prevUrl ? (
        <a class="pager__link" rel="prev" href={prevUrl}>
          ← Newer
        </a>
      ) : (
        <span class="pager__link pager__link--disabled">← Newer</span>
      )}

      <span class="pager__status">
        Page {current} of {last}
      </span>

      {nextUrl ? (
        <a class="pager__link" rel="next" href={nextUrl}>
          Older →
        </a>
      ) : (
        <span class="pager__link pager__link--disabled">Older →</span>
      )}
    </nav>
  )
}

<style>
  .pager {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin: 2.5rem 0 1rem;
    font-size: 0.9rem;
  }

  .pager__link {
    text-decoration: none;
    font-weight: 600;
    color: var(--ink);
  }

  .pager__link:hover {
    color: var(--red);
  }

  .pager__link--disabled {
    color: var(--stone);
    opacity: 0.5;
  }

  .pager__status {
    color: var(--stone);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.75rem;
  }
</style>
