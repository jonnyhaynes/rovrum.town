# Copy to .env and adjust for your machine. Never commit .env.

# --- Database (Postgres) ---
# Matches infra/docker-compose.yml defaults. Use this from the host (pnpm, tests).
DATABASE_URL="postgresql://rovrum:rovrum@localhost:5432/rovrum?schema=public"
# Only needed if you override the workers container's DB URL. Inside the compose
# network Postgres is reachable as host "postgres" (the compose default already
# uses this — set this only to point the container elsewhere).
# DATABASE_URL_DOCKER="postgresql://rovrum:rovrum@postgres:5432/rovrum?schema=public"

# --- Ingestion worker (apps/workers) ---
# User-Agent sent when fetching feeds (several 403 a bare client). Optional; the
# worker has a sensible RovrumBot default.
# INGEST_USER_AGENT="Mozilla/5.0 (compatible; RovrumBot/1.0; +https://www.rovrum.town)"
# Cron for the dispatch tick (per-source cadence still gates actual work).
# INGEST_DISPATCH_CRON="*/5 * * * *"

# --- Object storage (Cloudflare R2 in prod; MinIO locally, S3-compatible) ---
# Matches infra/docker-compose.yml defaults.
S3_ENDPOINT="http://localhost:9000"
S3_REGION="auto"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET="rovrum"
